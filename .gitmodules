[submodule "src/python_payload/splat"]
	path = src/python_payload/splat
	url = https://github.com/cmu-argus-2/splat.git
[submodule "deps/Spice"]
	path = deps/Spice
	url = https://github.com/OpenSpace/Spice.git
[submodule "models"]
	path = models
	url = https://github.com/cmu-argus-2/Vision-Models.git
	branch = dvc
[submodule "deps/spdlog"]
	path = deps/spdlog
	url = https://github.com/gabime/spdlog.git
[submodule "deps/googletest"]
	path = deps/googletest
	url = https://github.com/google/googletest.git
[submodule "deps/Ipopt"]
	path = deps/Ipopt
	url = https://github.com/coin-or/Ipopt
	ignore = untracked
[submodule "deps/casadi"]
	path = deps/casadi
	url = https://github.com/casadi/casadi.git
	ignore = untracked
